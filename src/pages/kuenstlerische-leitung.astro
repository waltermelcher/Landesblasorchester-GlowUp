---
import PageLayout from '../layouts/PageLayout.astro';
import { url } from '../lib/site';

const cv = [
  { y: '2004', t: 'Bachelor Dirigieren, Konservatorium Groningen (bei Alex Schillings)' },
  { y: '2004', t: 'Posaunenstudium bei Harrie Ries, Konservatorium Maastricht' },
  { y: '2005–06', t: 'Barockposaune bei Wim Becu, Hochschule für Musik Aachen' },
  { y: '2010', t: 'Master Dirigieren, Konservatorium Maastricht (bei Jan Cober)' },
];

const roles = [
  'General Artistic Manager des World Music Contest (Kerkrade)',
  'Dirigent des Nederlands Douane Orkest',
  'Künstlerischer Leiter des Landesblasorchesters BW (seit 2014)',
  'Vorstandsmitglied der WASBE',
  'Gefragter Gastdirigent und Juror auf internationaler Ebene',
];

const formerDirectors = [
  { n: 'Prof. Richard Zettler', y: '1978–1980' },
  { n: 'Alban Nieder', y: '1980–1986' },
  { n: 'Harry D. Bath', y: '1986–1996' },
  { n: 'Heinz Friesen', y: '1997' },
  { n: 'Walter Ratzek', y: '1998–2001' },
  { n: 'Isabelle Ruf-Weber', y: '2004–2013' },
  { n: 'Björn Bus', y: 'seit 2014' },
];
---
<PageLayout
  title="Künstlerische Leitung"
  section="Orchester"
  eyebrow="Dirigent"
  lead="Seit 2014 prägt Björn Bus den unverwechselbaren Klang des Landesblasorchesters Baden-Württemberg."
>
  <section class="section">
    <div class="wrap">
      <div class="surface" style="overflow:hidden;display:grid;grid-template-columns:0.85fr 1.15fr" data-reveal>
        <div style="position:relative;min-height:420px">
          <img src={url('/images/bjoern-bus-portrait.jpg')} alt="Björn Bus" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:top" />
        </div>
        <div class="card-pad" style="padding:clamp(1.6rem,3vw,2.5rem)">
          <span class="tag">Künstlerische Leitung seit 2014</span>
          <h2 style="margin:0.8rem 0 0.3rem">Björn Bus</h2>
          <p class="muted">* 1980 in Brunssum, Niederlande</p>
          <p style="margin-top:1rem">Björn Bus zählt zu den profiliertesten Dirigenten der internationalen Blasmusikszene. Er leitete u. a. das Orchester der Koninklijke Marine (Bronze, WMC 2009), wurde 2005 Zweiter beim Wettbewerb der European Brass Band Association und gibt regelmäßig Meisterkurse.</p>
          <p style="margin-top:0.8rem"><a class="link-wine" href="http://www.bjornbus.nl/de/" target="_blank" rel="noopener">bjornbus.nl ↗</a></p>
        </div>
      </div>

      <div class="grid grid-2" style="margin-top:2.5rem;align-items:start">
        <div class="surface card-pad" data-reveal>
          <h3 style="color:var(--ink)">Ausbildung</h3>
          <div class="stack" style="margin-top:1rem">
            {cv.map((c) => (
              <div style="display:grid;grid-template-columns:90px 1fr;gap:1rem;padding-bottom:0.8rem;border-bottom:1px solid var(--line)">
                <span style="color:var(--wine-soft);font-weight:600">{c.y}</span>
                <span style="color:var(--fg-dim)">{c.t}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="surface card-pad" data-reveal style="--delay:.08s">
          <h3 style="color:var(--ink)">Wirken &amp; Positionen</h3>
          <ul style="list-style:none;padding:0;margin-top:1rem">
            {roles.map((r) => (
              <li style="display:flex;gap:0.6rem;padding:0.5rem 0;color:var(--fg-dim);border-bottom:1px solid var(--line)"><span style="color:var(--wine-soft)">♪</span>{r}</li>
            ))}
          </ul>
        </div>
      </div>

      <h2 data-reveal style="margin-top:3.5rem">Bisherige künstlerische Leiter</h2>
      <div class="pill-row" style="margin-top:1.2rem" data-reveal>
        {formerDirectors.map((d) => (
          <span class="tag">{d.n} · {d.y}</span>
        ))}
      </div>
      <p class="muted" style="margin-top:1.5rem">Gastdirigenten u. a.: Miguel Echegoncelay, Prof. Andreas Kraft, Peter Vierneisel, Bernhard Volk, Wolfgang Wössner, Philipp Kufner, Johan de Meij, Franco Cesarini.</p>
    </div>
  </section>
</PageLayout>
