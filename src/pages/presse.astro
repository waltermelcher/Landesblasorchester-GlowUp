---
import PageLayout from '../layouts/PageLayout.astro';

const materials = [
  { h: 'Logo-Paket', t: 'Logovarianten als PNG und SVG.', meta: 'LBO-Logo-Presse.zip' },
  { h: 'Infomappe', t: 'Umfassendes Informationspaket zum Orchester.', meta: 'Landesblasorchester-Infomappe.pdf' },
  { h: 'Orchesterfotos', t: 'Vier Orchesterbilder in hoher Auflösung. Fotos: Sabrina Kilian.', meta: '4 Bilder · hochauflösend' },
  { h: 'Dirigentenfotos', t: 'Drei Porträts von Björn Bus in hoher Auflösung.', meta: '3 Bilder · hochauflösend' },
];
---
<PageLayout
  title="Presse"
  section="Medien"
  eyebrow="Pressebereich"
  lead="Materialien für Ihre Berichterstattung über das Landesblasorchester Baden-Württemberg."
>
  <section class="section">
    <div class="wrap">
      <div class="grid grid-2">
        {materials.map((m, i) => (
          <div class="card card-pad" data-reveal style={`--delay:${(i % 2) * 0.06}s`}>
            <span class="tag">Download</span>
            <h3 style="color:#fff;margin-top:0.8rem">{m.h}</h3>
            <p style="margin-top:0.5rem">{m.t}</p>
            <p class="muted" style="font-size:0.82rem;margin-top:0.8rem">{m.meta}</p>
          </div>
        ))}
      </div>
      <div class="surface card-pad" data-reveal style="margin-top:2rem">
        <p>Für Pressematerial und Interviewanfragen wenden Sie sich an unseren Kommunikationsreferenten Walter Melcher: <a class="link-wine" href="mailto:walter.melcher@landesblasorchester.de">walter.melcher@landesblasorchester.de</a></p>
      </div>
    </div>
  </section>
</PageLayout>
