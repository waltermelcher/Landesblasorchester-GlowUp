---
import PageLayout from '../layouts/PageLayout.astro';

const pieces = [
  { title: 'Jubilee Overture', year: '1984', composer: 'Philip Sparke', life: '*1951', desc: 'Festliche Blechbläser-Fanfaren und virtuose rhythmische Wendungen mit kontrastreicher Instrumentierung.' },
  { title: 'Danse funambulesque', year: '1925/1930', composer: 'Jules Strens', life: '1893–1971', desc: 'Polyrhythmische Experimente, die emotionale Reaktionen auf bedrohliche Situationen vertonen.' },
  { title: 'Resurrection', year: '2022', composer: 'Kevin Houben', life: '*1977', desc: 'Inspiriert von Mahlers zweiter Sinfonie — ein Werk über Vergänglichkeit und Auferstehung.' },
  { title: 'Marsch aus „Promenadenmusik“', year: '1926', composer: 'Hans Gál', life: '1890–1987', desc: 'Charmanter Konzertmarsch aus der frühen Moderne.' },
  { title: 'Drei-Klänge der Heimat', year: '2026', composer: 'Frederik Abel', life: '*2003', desc: 'Die Siegerkomposition: drei deutsche Volkslieder, frisch und kunstvoll neu instrumentiert. Uraufführung in Donaueschingen.' },
  { title: 'Symphonie de Paris', year: '1975', composer: 'Serge Lancen', life: '1922–2005', desc: 'Ein musikalischer Spaziergang durch die französische Hauptstadt.' },
  { title: 'Echoes of San Marco', year: '2016', composer: 'Johan de Meij', life: '*1953', desc: 'Hommage an den Renaissance-Komponisten Giovanni Gabrieli — Blechbläserchöre im Dialog.' },
];
---
<PageLayout
  title="Programm"
  section="Konzerte"
  eyebrow="Saison 2026"
  lead="Das aktuelle Konzertprogramm — von festlichen Ouvertüren über zeitgenössische Werke bis zur Uraufführung der Siegerkomposition."
>
  <section class="section">
    <div class="wrap stack">
      {pieces.map((p, i) => (
        <div class="surface card-pad" data-reveal style={`--delay:${i * 0.05}s;display:grid;grid-template-columns:auto 1fr;gap:1.4rem;align-items:start`}>
          <div class="avatar" aria-hidden="true">{String(i + 1)}</div>
          <div>
            <h3 style="color:#fff;font-size:1.3rem">{p.title} <span style="color:var(--fg-mut);font-weight:500;font-size:0.95rem">({p.year})</span></h3>
            <p style="color:var(--wine-soft);margin-top:0.25rem;font-weight:600">{p.composer} <span class="muted" style="font-weight:400">{p.life}</span></p>
            <p style="margin-top:0.6rem">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</PageLayout>
