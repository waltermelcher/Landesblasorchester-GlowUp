---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site, url, isProductionBuild, previewHostPatterns } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}
const { title, description = 'Sinfonische Blasmusik der Spitzenklasse — das Auswahlorchester des Blasmusikverbandes Baden-Württemberg e.V.' } = Astro.props;
const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.claim}`;

// Indexierung: Produktion -> index, Staging/Vorschau -> noindex (siehe lib/site.ts)
const robots = isProductionBuild ? 'index, follow' : 'noindex, nofollow';

// Startseite: Header überlagert den dunklen Hero (transparente NavBar am Top)
const norm = (p: string) => p.replace(/\/+$/, '') || '/';
const isHome = norm(Astro.url.pathname) === norm(url('/'));
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <script is:inline define:vars={{ patterns: previewHostPatterns }}>
      // Laufzeit-Schutz: auf jeder Vorschau-/Staging-Domain immer noindex erzwingen,
      // unabhängig vom Build (z. B. falls ein Prod-Build versehentlich auf github.io läuft).
      (function () {
        try {
          var h = location.hostname;
          var preview = false;
          for (var i = 0; i < patterns.length; i++) {
            var p = patterns[i];
            if (p.charAt(0) === '.' ? h.slice(-p.length) === p : (h === p || h.indexOf(p) !== -1)) {
              preview = true;
              break;
            }
          }
          if (preview) {
            var m = document.querySelector('meta[name="robots"]');
            if (m) m.setAttribute('content', 'noindex, nofollow');
          }
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&family=Permanent+Marker&display=swap" rel="stylesheet" />
  </head>
  <body class={isHome ? 'home' : undefined}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Dezente Reveal-on-scroll Animation (smooth, nicht aufdringlich)
      const els = document.querySelectorAll('[data-reveal]');
      if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('in'));
      }
    </script>
  </body>
</html>
